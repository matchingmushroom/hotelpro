# ──────────────────────────
# FRONTEND (copy to frontend/.env)
# ──────────────────────────
REACT_APP_SUPABASE_URL=http://localhost:54321
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key
REACT_APP_GAS_URL=https://script.google.com/macros/s/your-deploy-id/exec
REACT_APP_GEMINI_API_KEY=your-gemini-api-key
REACT_APP_BACKEND_URL=http://localhost:5000
REACT_APP_HOTEL_NAME=Otel.Pro

# ──────────────────────────
# BACKEND (copy to backend/.env)
# ──────────────────────────
PORT=5000
CORS_ORIGINS=http://localhost:3000
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@otelpro.com

# Supabase (used by backup scheduler)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
